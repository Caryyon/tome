  "identity": {
    "name": {
      "primary": "Elara Moonwhisper",
      "alternate": ["The Silver Sage", "Moonshadow"],
      "pronunciation": "eh-LAH-rah moon-WHIS-per"
    },
    "classification": {
      "race": "High Elf",
      "profession": "Archmage",
      "rank": "Court Wizard",
      "experience": "Veteran"
    },
    "description": {
      "short": "An elderly elven wizard with silver hair and piercing violet eyes",
      "full": "Elara is a renowned archmage who has served the kingdom for over three centuries. Her mastery of elemental magic is legendary, and she's known for her wisdom and patience in teaching young mages.",
      "appearance": "Tall and graceful, with flowing silver hair that seems to shimmer with its own light. Wears elegant robes of deep purple adorned with silver moon symbols. Her violet eyes seem to see beyond the mortal realm.",
      "personality": "Wise, patient, and contemplative. Values knowledge above all else. Can be stern with those who disrespect magic, but deeply caring toward her students."
    }
  },
