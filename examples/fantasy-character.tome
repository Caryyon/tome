  "narrative": {
    "background": "Born in the ancient Moonwood Forest, Elara showed exceptional magical talent from a young age. She studied at the Tower of Stars for a century before becoming the youngest archmage in the kingdom's history. She has served as Court Wizard for the past two hundred years, advising five generations of monarchs.",
    "personality": "Elara values knowledge and wisdom above all else. She believes that magic is a sacred trust that must be used responsibly. While she can be stern with those who disrespect the arcane arts, she is deeply caring toward her students and will go to great lengths to protect the innocent.",
    "goals": [
      "Preserve ancient magical knowledge",
      "Train the next generation of mages",
      "Uncover the secrets of the Void Between Stars",
      "Prevent the rise of dark magic in the kingdom"
    ],
    "bonds": [
      {
        "entity": "King Aldric III",
        "relationship": "advisor",
        "description": "Has served the current king for 25 years"
      },
      {
        "entity": "Theron Stormwind",
        "relationship": "apprentice",
        "description": "Her most promising student"
      },
      {
        "entity": "The Council of Mages",
        "relationship": "member",
        "description": "Senior member and former leader"
      }
    ],
    "history": [
      {
