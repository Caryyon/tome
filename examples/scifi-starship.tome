  "narrative": {
    "background": "The SSV Wanderer was commissioned in 2384 as part of the Deep Space Exploration Initiative. She has completed 15 successful long-range missions, discovering three new star systems and making first contact with two alien civilizations.",
    "personality": "The ship has developed a reputation among its crew as being 'lucky' - narrowly avoiding disasters on multiple occasions. The crew believes the ship has a personality of her own.",
    "goals": [
      "Complete the survey of the Kepler Expanse",
      "Search for signs of the lost colony ship Endeavor",
      "Map gravitational anomalies in Sector 7"
    ],
    "history": [
      {
        "date": "2384-03-15",
        "event": "Commissioned and launched from Mars Orbital Shipyards"
      },
      {
        "date": "2385-07-22",
        "event": "Discovered habitable planet in the Centauri system"
      },
      {
        "date": "2386-11-03",
        "event": "Survived encounter with spatial anomaly in the Void"
      },
      {
        "date": "2387-04-18",
        "event": "Made first contact with the Xel'nari civilization"
      },
      {
        "date": "2388-09-30",
        "event": "Underwent major refit with upgraded weapons and sensors"
      }
    ],
    "notes": "Currently on a 2-year mission to explore the Kepler Expanse, a largely uncharted region of space."
  },
